events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    server {
        listen 80;

        # For variable-based proxy_pass, nginx needs an explicit resolver.
        # Render doesn't provide Docker's 127.0.0.11 resolver, so use public DNS.
        resolver 1.1.1.1 8.8.8.8 valid=30s;

        # Serve static SPA
        location / {
            root   /usr/share/nginx/html;
            index  index.html;
            try_files $uri $uri.html $uri/ /index.html;
        }

        # Proxy API requests to backend (set via BACKEND_URL)
        location /api {
            set $backend_url ${BACKEND_URL};
            proxy_pass $backend_url;

            # Keep backend Host for multi-service routing (e.g. *.onrender.com)
            proxy_set_header Host $proxy_host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Host $host;

            proxy_ssl_server_name on;
            proxy_connect_timeout 60s;
            proxy_read_timeout 60s;
        }

        # Health check
        location /health {
            return 200 'OK';
        }
    }
}

